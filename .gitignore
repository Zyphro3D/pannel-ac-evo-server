docker/aceserver/*.dll
docker/aceserver/*.kspkg
docker/aceserver/*.ico
docker/aceserver/*.json
docker/aceserver/steamapps/
docker/aceserver/_CommonRedist/
docker/aceserver/content/
docker/aceserver/results/
# Garder les fichiers de config et exemples
!docker/aceserver/configs/
!docker/aceserver/configs/*.json

