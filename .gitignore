# Environnement
.env
.env.*
!.env.example
!.env.example.*

# Babel — fichier source régénéré automatiquement
messages.pot

# Base de données (runtime)
instance/

# État du serveur (runtime)
.server_state
.server_output.log
.server_pid

# Logs applicatifs
logs/

