# Environnement
.env
.env.*
!.env.example
!.env.example.*

# Babel — fichier source régénéré automatiquement
messages.pot

# Base de données (runtime)
instance/

# Paramètres panel (générés à l'exécution, contiennent des données sensibles)
data/

# État du serveur (runtime)
.server_state
.server_output.log
.server_pid

# Logs applicatifs
logs/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/

# Babel compilé — inclus dans le repo pour éviter l'étape de compilation manuelle
# Régénérer avec : python compile_mo.py

# aceserver — binaires et fichiers runtime du jeu (installés via SteamCMD, pas versionnés)
aceserver/*.exe
aceserver/*.dll
aceserver/*.kspkg
aceserver/*.ico
aceserver/*.json
aceserver/*.so
aceserver/linux64/
aceserver/.*
aceserver/steamapps/
aceserver/_CommonRedist/
aceserver/content/
aceserver/serverConfig/
aceserver/results/
# Configs serveur — éditées par l'utilisateur, non versionnées (le panel les génère au démarrage)
aceserver/configs/*.json
# Les templates .example sont versionnés pour guider la première installation
!aceserver/configs/*.json.example
aceserver/configs/server-*/

# Assets uploadés à l'exécution (bannière/logo perso, aperçus mail) — spécifiques
# à chaque instance, jamais versionnés. cars/ et circuits/ sont livrés avec le
# projet (photos par défaut des véhicules/circuits officiels) et NE sont PAS ignorés.
media/banner/
media/mail/
media/events/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code
CLAUDE.md
.claude/
AUDIT.md

# Notes internes — pas destinées au dépôt public
ROADBOOK.md

# Fichiers locaux uniquement : audits, notes de travail, suite de tests pytest —
# rien ici n'est nécessaire à l'application ni destiné au dépôt public/aux archives
# de release (le script de build de .github/workflows/release.yml zippe tout ce
# qui n'est pas explicitement exclu, donc ce qui traîne à la racine finit livré
# aux utilisateurs). Tout nouveau fichier de ce genre va dans .local/.
.local/

# Docker override — généré dynamiquement par le panel (données spécifiques à l'instance)
docker-compose.override.yml

# CSS compilé par le build Docker — le fichier local peut diverger du build
app/static/css/tailwind.min.css

# Dépendances Node.js — installées dans l'image Docker, pas dans le repo
node_modules/

# Artefacts des tests Playwright (screenshots/traces des échecs)
test-results/
playwright-report/

# OS
Thumbs.db
.DS_Store
desktop.ini
slice_thumbnails.py
tools/
