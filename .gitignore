__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/

# Babel compilé — inclus dans le repo pour éviter l'étape de compilation manuelle
# Régénérer avec : python compile_mo.py

# Fichiers runtime du serveur ACE (générés par le jeu)
serverConfig/
system/

# docker/aceserver — binaires du jeu (installés via SteamCMD, pas versionnés)
