# Environnement
.env
.env.*
!.env.example
!.env.example.*

# Babel — fichier source régénéré automatiquement
messages.pot

# Base de données (runtime)
instance/

# État du serveur (runtime)
.server_state
.server_output.log
.server_pid

# Logs applicatifs
logs/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/

# Babel compilé — inclus dans le repo pour éviter l'étape de compilation manuelle
# Régénérer avec : python compile_mo.py

# aceserver — binaires et fichiers runtime du jeu (installés via SteamCMD, pas versionnés)
aceserver/*.exe
aceserver/*.dll
aceserver/*.kspkg
aceserver/*.ico
aceserver/*.json
aceserver/*.so
aceserver/linux64/
aceserver/.*
aceserver/steamapps/
aceserver/_CommonRedist/
aceserver/content/
aceserver/serverConfig/
aceserver/results/
# Garder les configs-templates versionnées ; exclure les dossiers runtime par serveur
!aceserver/configs/
!aceserver/configs/*.json
aceserver/configs/server-*/

# Assets uploadés (générés à l'exécution, pas versionnés)
media/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store
desktop.ini
slice_thumbnails.py
tools/
