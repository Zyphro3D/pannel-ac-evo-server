msgstr "URL pública del panel (enlaces en los correos)"

#: app/routes/admin.py:559
msgid "Fuseau horaire (ex: Europe/Paris)"
msgstr "Zona horaria (ej: Europe/Paris)"

#: app/routes/admin.py:560
msgid ""
"Clé de session Flask — générer avec python -c \"import secrets; "
"print(secrets.token_hex(32))\""
msgstr ""
"Clave de sesión Flask — generar con python -c \"import secrets; "
"print(secrets.token_hex(32))\""

#: app/routes/admin.py:561
msgid "true si HTTPS, false si HTTP local"
msgstr "true si HTTPS, false si HTTP local"

#: app/routes/admin.py:562
msgid "Secret HMAC du webhook résultats (/api/results/ingest)"
msgstr "Secreto HMAC del webhook de resultados (/api/results/ingest)"

#: app/routes/admin.py:563
msgid ""
"Exige que les pilotes confirment leur email (lien envoyé à l'inscription)"
" avant de pouvoir s'inscrire à un événement. Les comptes existants ne "
"sont pas affectés rétroactivement."
msgstr ""
"Exige que los pilotos confirmen su correo (enlace enviado al registrarse)"
" antes de poder inscribirse a un evento. Las cuentas existentes no se ven"
" afectadas retroactivamente."

#: app/routes/admin.py:564
msgid ""
"Nombre de mois de conservation détaillée de l'historique des tours "
"(temps, voiture, circuit). Au-delà, archivé en résumé mensuel compact "
"plutôt que supprimé."
msgstr ""
"Número de meses durante los cuales se conserva el historial detallado de "
"vueltas (tiempo, coche, circuito). Más allá, se archiva como un resumen "
"mensual compacto en lugar de eliminarse."

#: app/routes/admin.py:565
msgid "Port HTTP de l'API du serveur (défaut 8081)"
msgstr "Puerto HTTP de la API del servidor (por defecto 8081)"

#: app/routes/admin.py:566
msgid "Hôte TCP ACE EVO (défaut 127.0.0.1)"
msgstr "Host TCP de ACE EVO (por defecto 127.0.0.1)"

#: app/routes/admin.py:567
msgid "Port TCP ACE EVO (défaut 9700)"
msgstr "Puerto TCP de ACE EVO (por defecto 9700)"

#: app/routes/admin.py:568
msgid "Dossier d'installation ACE EVO"
msgstr "Carpeta de instalación de ACE EVO"

#: app/routes/admin.py:569
msgid "Dossier des fichiers de configuration JSON"
msgstr "Carpeta de los archivos de configuración JSON"

#: app/routes/admin.py:570
msgid ""
"Nom du serveur affiché dans la liste des serveurs ACE EVO (commun à "
"toutes les configs)"
msgstr ""
"Nombre del servidor mostrado en la lista de servidores ACE EVO (común a "
"todas las configuraciones)"

#: app/routes/admin.py:571
msgid "Nombre maximum de joueurs simultanés (1–128, défaut 8)"
msgstr "Número máximo de jugadores simultáneos (1–128, por defecto 8)"

#: app/routes/admin.py:572
msgid ""
"Port TCP du serveur de jeu (défaut 9700) — doit correspondre aux règles "
"firewall"
msgstr ""
"Puerto TCP del servidor de juego (por defecto 9700) — debe coincidir con "
"las reglas del firewall"

#: app/routes/admin.py:573
msgid ""
"Port UDP du serveur de jeu (défaut 9700) — généralement identique au port"
" TCP"
msgstr ""
"Puerto UDP del servidor de juego (por defecto 9700) — normalmente igual "
"al puerto TCP"

#: app/routes/admin.py:574
msgid ""
"Mot de passe d'accès au serveur pour les pilotes. Laisser vide = accès "
"libre"
msgstr ""
"Contraseña de acceso al servidor para los pilotos. Dejar vacío = acceso "
"libre"

#: app/routes/admin.py:575
msgid ""
"Mot de passe admin serveur (commandes /kick, /next, etc.) — utilisé aussi"
" par le bot TCP"
msgstr ""
"Contraseña de administrador del servidor (comandos /kick, /next, etc.) — "
"también usada por el bot TCP"

#: app/routes/admin.py:576
msgid "Chemin vers le fichier entry_list.ini (laisser vide si non utilisé)"
msgstr "Ruta al archivo entry_list.ini (dejar vacío si no se usa)"

#: app/routes/admin.py:577
msgid ""
"Dossier de sortie des résultats de session (laisser vide = dossier par "
"défaut)"
msgstr ""
"Carpeta de salida de los resultados de sesión (dejar vacío = carpeta por "
"defecto)"

#: app/routes/admin.py:578
msgid ""
"Steam ID 64-bit du compte bot — le bot se connecte au serveur avec ce "
"compte. Laisser vide pour désactiver le bot."
msgstr ""
"Steam ID de 64 bits de la cuenta del bot — el bot se conecta al servidor "
"con esta cuenta. Dejar vacío para desactivar el bot."

#: app/routes/admin.py:579
msgid "Voiture utilisée par le bot pour rejoindre la session."
msgstr "Coche usado por el bot para unirse a la sesión."

#: app/routes/admin.py:580
msgid ""
"Activer les droits admin pour le bot (true/false). Le mot de passe est lu"
" automatiquement depuis la config serveur active."
msgstr ""
"Activar los derechos de administrador para el bot (true/false). La "
"contraseña se lee automáticamente desde la configuración de servidor "
"activa."

#: app/routes/admin.py:581
#, python-brace-format
msgid ""
"Message de bienvenue envoyé à chaque connexion. Variable : {name}. "
"Laisser vide pour désactiver."
msgstr ""
"Mensaje de bienvenida enviado en cada conexión. Variable: {name}. Dejar "
"vacío para desactivar."

#: app/routes/admin.py:582
#, python-brace-format
msgid ""
"Message Discord envoyé si DISCORD_INVITE_URL est défini. Variables : "
"{name}, {discord_url}. Laisser vide pour désactiver."
msgstr ""
"Mensaje de Discord enviado si DISCORD_INVITE_URL está definido. "
"Variables: {name}, {discord_url}. Dejar vacío para desactivar."

#: app/routes/admin.py:583
#, python-brace-format
msgid ""
"Message site envoyé si PANEL_URL est défini. Variables : {name}, "
"{site_url}. Laisser vide pour désactiver."
msgstr ""
"Mensaje del sitio enviado si PANEL_URL está definido. Variables: {name}, "
"{site_url}. Dejar vacío para desactivar."

#: app/routes/admin.py:584
msgid ""
"Pré-remplit le formulaire de mise à jour. Le mot de passe est saisi au "
"moment de la mise à jour, jamais stocké."
msgstr ""
"Rellena previamente el formulario de actualización. La contraseña se "
"introduce en el momento de la actualización, nunca se almacena."

#: app/routes/admin.py:585
msgid "Webhook principal — démarrage, arrêt, crash du serveur"
msgstr "Webhook principal — inicio, parada, caída del servidor"

#: app/routes/admin.py:586
msgid "Webhook pilotes — connexions, déconnexions, changements de véhicule"
msgstr "Webhook de pilotos — conexiones, desconexiones, cambios de vehículo"

#: app/routes/admin.py:587
msgid "Webhook course — meilleur tour, actions admin (kick, pénalités…)"
msgstr ""
"Webhook de carrera — mejor vuelta, acciones de administrador (kick, "
"penalizaciones…)"

#: app/routes/admin.py:588
msgid "Lien d'invitation Discord affiché sur le panel"
msgstr "Enlace de invitación a Discord mostrado en el panel"

#: app/routes/admin.py:589
msgid ""
"Mention envoyée avec les événements serveur (ex: @here ou <@&123456789>)."
" Laisser vide pour désactiver."
msgstr ""
"Mención enviada con los eventos del servidor (ej: @here o <@&123456789>)."
" Dejar vacío para desactivar."

#: app/routes/admin.py:590
msgid "Mention envoyée avec les connexions joueurs. Laisser vide pour désactiver."
msgstr ""
"Mención enviada con las conexiones de jugadores. Dejar vacío para "
"desactivar."

#: app/routes/admin.py:591
msgid "Mention envoyée avec les événements course. Laisser vide pour désactiver."
msgstr "Mención enviada con los eventos de carrera. Dejar vacío para desactivar."

#: app/routes/admin.py:592
#, python-brace-format
msgid "Titre embed — Serveur démarré. Variables : {config}, {mode}, {circuit}"
msgstr ""
"Título del embed — Servidor iniciado. Variables: {config}, {mode}, "
"{circuit}"

#: app/routes/admin.py:593
#, python-brace-format
msgid "Titre embed — Serveur arrêté. Variables : {config}"
msgstr "Título del embed — Servidor detenido. Variables: {config}"

#: app/routes/admin.py:594
#, python-brace-format
msgid "Titre embed — Crash détecté. Variables : {config}"
msgstr "Título del embed — Caída detectada. Variables: {config}"

#: app/routes/admin.py:595
#, python-brace-format
msgid ""
"Titre embed — Connexion joueur. Variables : {name}, {num}, {car}, "
"{steam_id}"
msgstr ""
"Título del embed — Conexión de jugador. Variables: {name}, {num}, {car}, "
"{steam_id}"

#: app/routes/admin.py:596
#, python-brace-format
msgid ""
"Titre embed — Déconnexion joueur. Variables : {name}, {duration}, "
"{steam_id}"
msgstr ""
"Título del embed — Desconexión de jugador. Variables: {name}, {duration},"
" {steam_id}"

#: app/routes/admin.py:597
#, python-brace-format
msgid ""
"Titre embed — Changement de véhicule. Variables : {name}, {num}, "
"{old_car}, {new_car}"
msgstr ""
"Título del embed — Cambio de vehículo. Variables: {name}, {num}, "
"{old_car}, {new_car}"

#: app/routes/admin.py:598
#, python-brace-format
msgid "Titre embed — Meilleur tour serveur. Variables : {name}, {lap}, {car}"
msgstr ""
"Título del embed — Mejor vuelta del servidor. Variables: {name}, {lap}, "
"{car}"

#: app/routes/admin.py:599
#, python-brace-format
msgid ""
"Titre embed — Action admin. Variables : {action}, {target}, {admin}, "
"{detail}"
msgstr ""
"Título del embed — Acción de administrador. Variables: {action}, "
"{target}, {admin}, {detail}"

#: app/routes/admin.py:600
msgid "Serveur SMTP (laisser vide pour désactiver les emails)"
msgstr "Servidor SMTP (dejar vacío para desactivar los correos)"

#: app/routes/admin.py:601
msgid "Port SMTP (ex: 587 ou 465)"
msgstr "Puerto SMTP (ej: 587 o 465)"

