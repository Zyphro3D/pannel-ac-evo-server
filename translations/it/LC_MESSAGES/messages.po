#: app/routes/admin.py:560
msgid ""
"Clé de session Flask — générer avec python -c \"import secrets; "
"print(secrets.token_hex(32))\""
msgstr ""
"Chiave di sessione Flask — generare con python -c \"import secrets; "
"print(secrets.token_hex(32))\""

#: app/routes/admin.py:561
msgid "true si HTTPS, false si HTTP local"
msgstr "true se HTTPS, false se HTTP locale"

