msgstr "Segreto HMAC del webhook risultati (/api/results/ingest)"

#: app/routes/admin.py:563
msgid ""
"Exige que les pilotes confirment leur email (lien envoyé à l'inscription)"
" avant de pouvoir s'inscrire à un événement. Les comptes existants ne "
"sont pas affectés rétroactivement."
msgstr ""
"Richiede che i piloti confermino la propria email (link inviato alla "
"registrazione) prima di potersi iscrivere a un evento. Gli account "
"esistenti non sono interessati retroattivamente."

#: app/routes/admin.py:564
msgid ""
"Nombre de mois de conservation détaillée de l'historique des tours "
"(temps, voiture, circuit). Au-delà, archivé en résumé mensuel compact "
"plutôt que supprimé."
msgstr ""
"Numero di mesi di conservazione dettagliata della cronologia dei giri "
"(tempo, auto, circuito). Oltre tale periodo, viene archiviata come "
"riepilogo mensile compatto anziché eliminata."

#: app/routes/admin.py:565
msgid "Port HTTP de l'API du serveur (défaut 8081)"
msgstr "Porta HTTP dell'API del server (default 8081)"

#: app/routes/admin.py:566
msgid "Hôte TCP ACE EVO (défaut 127.0.0.1)"
msgstr "Host TCP ACE EVO (default 127.0.0.1)"

#: app/routes/admin.py:567
msgid "Port TCP ACE EVO (défaut 9700)"
msgstr "Porta TCP ACE EVO (default 9700)"

#: app/routes/admin.py:568
msgid "Dossier d'installation ACE EVO"
msgstr "Cartella di installazione di ACE EVO"

#: app/routes/admin.py:569
msgid "Dossier des fichiers de configuration JSON"
msgstr "Cartella dei file di configurazione JSON"

#: app/routes/admin.py:570
msgid ""
"Nom du serveur affiché dans la liste des serveurs ACE EVO (commun à "
"toutes les configs)"
msgstr ""
"Nome del server visualizzato nell'elenco server ACE EVO (comune a tutte "
"le configurazioni)"

#: app/routes/admin.py:571
msgid "Nombre maximum de joueurs simultanés (1–128, défaut 8)"
msgstr "Numero massimo di giocatori simultanei (1–128, default 8)"

#: app/routes/admin.py:572
msgid ""
"Port TCP du serveur de jeu (défaut 9700) — doit correspondre aux règles "
"firewall"
msgstr ""
"Porta TCP del server di gioco (default 9700) — deve corrispondere alle "
"regole del firewall"

#: app/routes/admin.py:573
msgid ""
"Port UDP du serveur de jeu (défaut 9700) — généralement identique au port"
" TCP"
msgstr ""
"Porta UDP del server di gioco (default 9700) — solitamente identica alla "
"porta TCP"

#: app/routes/admin.py:574
msgid ""
"Mot de passe d'accès au serveur pour les pilotes. Laisser vide = accès "
"libre"
msgstr ""
"Password di accesso al server per i piloti. Lasciare vuoto = accesso "
"libero"

#: app/routes/admin.py:575
msgid ""
"Mot de passe admin serveur (commandes /kick, /next, etc.) — utilisé aussi"
" par le bot TCP"
msgstr ""
"Password admin del server (comandi /kick, /next, ecc.) — usata anche dal "
"bot TCP"

#: app/routes/admin.py:576
msgid "Chemin vers le fichier entry_list.ini (laisser vide si non utilisé)"
msgstr "Percorso del file entry_list.ini (lasciare vuoto se non utilizzato)"

#: app/routes/admin.py:577
msgid ""
"Dossier de sortie des résultats de session (laisser vide = dossier par "
"défaut)"
msgstr ""
"Cartella di output dei risultati di sessione (lasciare vuoto = cartella "
"predefinita)"

#: app/routes/admin.py:578
msgid ""
"Steam ID 64-bit du compte bot — le bot se connecte au serveur avec ce "
"compte. Laisser vide pour désactiver le bot."
msgstr ""
"Steam ID a 64 bit dell'account bot — il bot si connette al server con "
"questo account. Lasciare vuoto per disattivare il bot."

#: app/routes/admin.py:579
msgid "Voiture utilisée par le bot pour rejoindre la session."
msgstr "Auto utilizzata dal bot per unirsi alla sessione."

#: app/routes/admin.py:580
msgid ""
"Activer les droits admin pour le bot (true/false). Le mot de passe est lu"
" automatiquement depuis la config serveur active."
msgstr ""
"Attiva i diritti admin per il bot (true/false). La password viene letta "
"automaticamente dalla configurazione server attiva."

#: app/routes/admin.py:581
#, python-brace-format
msgid ""
"Message de bienvenue envoyé à chaque connexion. Variable : {name}. "
"Laisser vide pour désactiver."
msgstr ""
"Messaggio di benvenuto inviato ad ogni connessione. Variabile: {name}. "
"Lasciare vuoto per disattivare."

#: app/routes/admin.py:582
#, python-brace-format
msgid ""
"Message Discord envoyé si DISCORD_INVITE_URL est défini. Variables : "
"{name}, {discord_url}. Laisser vide pour désactiver."
msgstr ""
"Messaggio Discord inviato se DISCORD_INVITE_URL è impostato. Variabili: "
"{name}, {discord_url}. Lasciare vuoto per disattivare."

#: app/routes/admin.py:583
#, python-brace-format
msgid ""
"Message site envoyé si PANEL_URL est défini. Variables : {name}, "
"{site_url}. Laisser vide pour désactiver."
msgstr ""
"Messaggio del sito inviato se PANEL_URL è impostato. Variabili: {name}, "
"{site_url}. Lasciare vuoto per disattivare."

#: app/routes/admin.py:584
msgid ""
"Pré-remplit le formulaire de mise à jour. Le mot de passe est saisi au "
"moment de la mise à jour, jamais stocké."
msgstr ""
"Precompila il modulo di aggiornamento. La password viene inserita al "
"momento dell'aggiornamento, mai memorizzata."

#: app/routes/admin.py:585
msgid "Webhook principal — démarrage, arrêt, crash du serveur"
msgstr "Webhook principale — avvio, arresto, crash del server"

#: app/routes/admin.py:586
msgid "Webhook pilotes — connexions, déconnexions, changements de véhicule"
msgstr "Webhook piloti — connessioni, disconnessioni, cambi veicolo"

#: app/routes/admin.py:587
msgid "Webhook course — meilleur tour, actions admin (kick, pénalités…)"
msgstr "Webhook gara — miglior giro, azioni admin (kick, penalità…)"

#: app/routes/admin.py:588
msgid "Lien d'invitation Discord affiché sur le panel"
msgstr "Link di invito Discord mostrato sul pannello"

#: app/routes/admin.py:589
msgid ""
"Mention envoyée avec les événements serveur (ex: @here ou <@&123456789>)."
" Laisser vide pour désactiver."
msgstr ""
"Menzione inviata con gli eventi del server (es: @here o <@&123456789>). "
"Lasciare vuoto per disattivare."

#: app/routes/admin.py:590
msgid "Mention envoyée avec les connexions joueurs. Laisser vide pour désactiver."
msgstr ""
"Menzione inviata con le connessioni dei giocatori. Lasciare vuoto per "
"disattivare."

#: app/routes/admin.py:591
msgid "Mention envoyée avec les événements course. Laisser vide pour désactiver."
msgstr "Menzione inviata con gli eventi gara. Lasciare vuoto per disattivare."

