#, python-brace-format
msgid ""
"Titre embed — Connexion joueur. Variables : {name}, {num}, {car}, "
"{steam_id}"
msgstr ""
"Titolo embed — Connessione giocatore. Variabili: {name}, {num}, {car}, "
"{steam_id}"

#: app/routes/admin.py:596
#, python-brace-format
msgid ""
"Titre embed — Déconnexion joueur. Variables : {name}, {duration}, "
"{steam_id}"
msgstr ""
"Titolo embed — Disconnessione giocatore. Variabili: {name}, {duration}, "
"{steam_id}"

#: app/routes/admin.py:597
#, python-brace-format
msgid ""
"Titre embed — Changement de véhicule. Variables : {name}, {num}, "
"{old_car}, {new_car}"
msgstr ""
"Titolo embed — Cambio veicolo. Variabili: {name}, {num}, {old_car}, "
"{new_car}"

#: app/routes/admin.py:598
#, python-brace-format
msgid "Titre embed — Meilleur tour serveur. Variables : {name}, {lap}, {car}"
msgstr "Titolo embed — Miglior giro del server. Variabili: {name}, {lap}, {car}"

#: app/routes/admin.py:599
#, python-brace-format
msgid ""
"Titre embed — Action admin. Variables : {action}, {target}, {admin}, "
"{detail}"
msgstr ""
"Titolo embed — Azione admin. Variabili: {action}, {target}, {admin}, "
"{detail}"

