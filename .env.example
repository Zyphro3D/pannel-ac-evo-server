# ── Sécurité ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Comptes ──────────────────────────────────────────────────────────────────
# superadmin : accès complet (ports TCP/UDP visibles)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-superadmin

# admin : accès standard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Chemins ──────────────────────────────────────────────────────────────────
CONFIGS_DIR=C:\Users\Administrateur\Documents\ACE
ACESERVER_EXE_PATH=C:\aceserver\AssettoCorsaEVOServer.exe
CARS_JSON_PATH=C:\aceserver\cars.json
EVENTS_PRACTICE_JSON_PATH=C:\aceserver\events_practice.json
EVENTS_RACE_JSON_PATH=C:\aceserver\events_race_weekend.json

# ── Serveur ACE ──────────────────────────────────────────────────────────────
# Port HTTP de l'API du serveur de jeu (défaut : 8080)
ACESERVER_HTTP_PORT=8080

# Afficher la fenêtre console du serveur (true/false)
SERVER_SHOW_CONSOLE=false

# ── Intégrations ─────────────────────────────────────────────────────────────
# Laisser vide pour désactiver les notifications Discord
DISCORD_WEBHOOK_URL=
