# ═══════════════════════════════════════════════════════════════════════════════
#  AC EVO Server Panel — Configuration Docker
#  Copiez ce fichier vers docker/.env et renseignez chaque valeur.
#  Les chemins (ACESERVER_DIR, CONFIGS_DIR, DATABASE_URL) sont déjà
#  configurés dans le Dockerfile — ne les ajoutez pas ici.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Comptes admin ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# superadmin : accès complet (ports TCP/UDP/HTTP modifiables)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=

# ── Panel ─────────────────────────────────────────────────────────────────────
# Port d'écoute du panel (défaut : 4300) — doit correspondre au port exposé dans docker-compose
PANEL_PORT=4300

# URL publique du panel (utilisée dans les liens des emails)
PANEL_URL=https://<votre-domaine>

# Nom affiché dans la sidebar (laisser vide = "AC EVO Panel")
PANEL_TITLE=

# Images personnalisées (noms de fichiers dans media/banner/ — upload via Paramètres > Médias)
PANEL_BANNER_IMG=
PANEL_LOGO_IMG=

# URL GitHub du projet (affichée dans le footer — laisser vide pour masquer les liens)
PANEL_GITHUB_URL=https://github.com/Zyphro3D/pannel-ac-evo-server

# true derrière HTTPS (Caddy/Nginx), false en HTTP local
SESSION_COOKIE_SECURE=true

# Langue par défaut (fr / en / es / de / it)
DEFAULT_LOCALE=fr

# Fuseau horaire (pour les notifications Discord et l'affichage des heures)
# Exemples : Europe/Paris, Europe/London, America/New_York
PANEL_TIMEZONE=Europe/Paris

# ── HTTPS / SSL (optionnel) ───────────────────────────────────────────────────
# Trois modes possibles :
#   1. HTTP direct       : laisser vide, PANEL_PORT=4300
#   2. HTTPS intégré     : renseigner les deux chemins ci-dessous + PANEL_PORT=443
#   3. Reverse proxy     : laisser vide, gérer le SSL côté Nginx/Caddy/etc.
#
# Pour le mode HTTPS intégré, montez /etc/letsencrypt dans le container
# (voir docker-compose.yml, section commentée) et pointez vers vos certs :
SSL_CERTFILE=
SSL_KEYFILE=

# ── Discord (optionnel) ───────────────────────────────────────────────────────
# Webhook principal : démarrage / arrêt / crash du serveur
DISCORD_WEBHOOK_URL=

# Webhook pilotes : connexions / déconnexions joueurs, inscriptions, rappels
# Si vide, utilise le webhook principal
DISCORD_PILOTS_WEBHOOK_URL=

# Webhook course : meilleur tour du serveur, actions admin (kick, pénalités…)
# Si vide, utilise le webhook principal
DISCORD_RACE_WEBHOOK_URL=

# Lien d'invitation affiché sur le dashboard public
DISCORD_INVITE_URL=

# Mentions optionnelles envoyées avant l'embed (@here, <@&role_id>)
DISCORD_MENTION_MAIN=
DISCORD_MENTION_PILOTS=
DISCORD_MENTION_RACE=

# Titres des embeds — variables disponibles entre accolades {variable}
# Laisser vide = texte par défaut
DISCORD_MSG_SERVER_START=
DISCORD_MSG_SERVER_STOP=
DISCORD_MSG_SERVER_CRASH=
DISCORD_MSG_PLAYER_JOIN=
DISCORD_MSG_PLAYER_DISCONNECT=
DISCORD_MSG_VEHICLE_CHANGE=
DISCORD_MSG_BEST_LAP=
DISCORD_MSG_ADMIN_ACTION=

# Secret partagé pour signer le webhook /api/results/ingest.
# Signature attendue: HMAC-SHA256 du body brut dans X-ACE-Signature
# (format hex ou sha256=<hex>).
RESULTS_INGEST_SECRET=

# ── Configuration du serveur de jeu (globale, commune à toutes les configs) ──
# Ces valeurs sont injectées automatiquement dans les configs JSON au démarrage.
# Elles remplacent tout ce qui était autrefois dans l'éditeur de config.

# Nom affiché dans la liste des serveurs ACE EVO
SERVER_NAME=ACE EVO Server

# Nombre maximum de joueurs simultanés (1–128)
SERVER_MAX_PLAYERS=8

# Port TCP et UDP du serveur de jeu (doit correspondre aux règles firewall)
SERVER_TCP_PORT=9700
SERVER_UDP_PORT=9700

# Mot de passe d'accès pour les pilotes (laisser vide = serveur ouvert)
SERVER_DRIVER_PASSWORD=

# Mot de passe admin serveur (/kick, /next session…) — utilisé aussi par le bot TCP
SERVER_ADMIN_PASSWORD=

# Chemin vers le fichier entry_list.ini (laisser vide si non utilisé)
SERVER_ENTRY_LIST_PATH=

# Dossier de sortie des résultats de session (laisser vide = dossier par défaut)
SERVER_RESULTS_PATH=

# ── Chat in-game / leaderboard temps réel (optionnel) ────────────────────────
# Le panel peut se connecter au serveur ACE EVO en TCP (port 9700) pour :
#   - envoyer des messages dans le tchat du jeu depuis le panel
#   - afficher les temps au tour en temps réel sur la page Live
#
# ACE_BOT_STEAM_ID : Steam ID 64 bits à utiliser pour la connexion bot.
#   Ce joueur doit être inscrit à l'événement en cours dans l'entry list.
#   Laisser vide pour désactiver la fonctionnalité.
ACE_BOT_STEAM_ID=
# Modèle de voiture utilisé par le bot (doit correspondre à l'entry list)
ACE_BOT_CAR_MODEL=preset_190e_mech_1

# Activer les droits admin pour le bot (true/false)
# Le mot de passe admin est lu automatiquement depuis la config serveur active
ACE_BOT_IS_ADMIN=false

# Messages envoyés par le bot au moment de la connexion d'un joueur
# Variables disponibles entre accolades selon le message
# Laisser vide pour désactiver
ACE_BOT_MSG_WELCOME=
ACE_BOT_MSG_DISCORD=
ACE_BOT_MSG_SITE=

# ── Email SMTP (optionnel) ────────────────────────────────────────────────────
# Laisser MAIL_SERVER vide pour désactiver les emails
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
# Adresses admin pour les notifications (séparées par des virgules)
MAIL_ADMIN=
