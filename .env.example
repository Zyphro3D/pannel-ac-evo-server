# ── Sécurité ────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Comptes admin ─────────────────────────────────────────────────────────────
# superadmin : accès complet (ports TCP/UDP/HTTP visibles et modifiables)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-superadmin

# admin : accès standard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Chemins ──────────────────────────────────────────────────────────────────
# Dossier contenant les fichiers de config .json du panel
CONFIGS_DIR=C:\Users\<user>\Documents\ACE

# Dossier d'installation du serveur de jeu.
# Les fichiers cars.json, events_practice.json, events_race_weekend.json
# et AssettoCorsaEVOServer.exe sont cherchés automatiquement dans ce dossier.
ACESERVER_DIR=C:\aceserver

# ── Serveur ACE ──────────────────────────────────────────────────────────────
# Port HTTP de l'API du serveur de jeu (défaut : 8080)
ACESERVER_HTTP_PORT=8080

# Afficher la fenêtre console du serveur (true/false)
SERVER_SHOW_CONSOLE=false

# ── Base de données ───────────────────────────────────────────────────────────
# SQLite par défaut (chemin relatif au dossier d'exécution)
# Pour PostgreSQL : postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///ace_evo.db

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Laisser MAIL_SERVER vide pour désactiver les emails
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=panel@example.com
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=panel@example.com
# Email de l'administrateur (reçoit les notifications d'inscription)
MAIL_ADMIN=admin@example.com

# ── URL publique du panel ─────────────────────────────────────────────────────
# Utilisée dans les liens des emails
PANEL_URL=https://<your domain>

# ── Intégrations ─────────────────────────────────────────────────────────────
# Laisser vide pour désactiver les notifications Discord
DISCORD_WEBHOOK_URL=

# Mettre false si accès en HTTP local
SESSION_COOKIE_SECURE=true
