# ═══════════════════════════════════════════════════════════════════════════════
#  AC EVO Server Panel — Configuration Docker
#  Copiez ce fichier vers docker/.env et renseignez chaque valeur.
#  Les chemins (ACESERVER_DIR, CONFIGS_DIR, DATABASE_URL) sont déjà
#  configurés dans le Dockerfile — ne les ajoutez pas ici.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Comptes admin ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# superadmin : accès complet (ports TCP/UDP/HTTP modifiables)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-superadmin

# ── Panel ─────────────────────────────────────────────────────────────────────
# URL publique du panel (utilisée dans les liens des emails)
PANEL_URL=https://<votre-domaine>

# true derrière HTTPS (Caddy/Nginx), false en HTTP local
SESSION_COOKIE_SECURE=true

# Langue par défaut (fr / en / es / de / it)
DEFAULT_LOCALE=fr

# Fuseau horaire (pour les notifications Discord et l'affichage des heures)
# Exemples : Europe/Paris, Europe/London, America/New_York
PANEL_TIMEZONE=Europe/Paris

# ── Discord (optionnel) ───────────────────────────────────────────────────────
# Webhook principal : démarrage / arrêt / crash du serveur
DISCORD_WEBHOOK_URL=

# Webhook pilotes : inscriptions, rappels d'événements
# Si vide, utilise le webhook principal
DISCORD_PILOTS_WEBHOOK_URL=

# Lien d'invitation affiché sur le dashboard public
DISCORD_INVITE_URL=

# ── Email SMTP (optionnel) ────────────────────────────────────────────────────
# Laisser MAIL_SERVER vide pour désactiver les emails
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
# Adresses admin pour les notifications (séparées par des virgules)
MAIL_ADMIN=
