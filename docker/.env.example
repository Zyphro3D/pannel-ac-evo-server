# Copier ce fichier en .env et remplir les valeurs
# Copy this file to .env and fill in the values

# ── Sécurité / Security ───────────────────────────────────────────────────────
# Générer avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-with-a-random-hex-key

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me

# ── Panel ─────────────────────────────────────────────────────────────────────
PANEL_URL=http://localhost:4300
PANEL_TIMEZONE=Europe/Paris
DEFAULT_LOCALE=fr

# ── Serveur ACE EVO ───────────────────────────────────────────────────────────
# Chemin vers le .exe à l'intérieur du volume monté (/aceserver)
ACESERVER_EXE_PATH=/aceserver/AssettoCorsaEVOServer.exe
ACESERVER_HTTP_PORT=8080

# ── Discord (optionnel) ───────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
DISCORD_PILOTS_WEBHOOK_URL=
DISCORD_INVITE_URL=

# ── Email SMTP (optionnel) ────────────────────────────────────────────────────
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_ADMIN=
